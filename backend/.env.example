# Copy this file to ".env" and change the values before going live.

# Port the backend listens on
PORT=4000

# Secret used to sign login tokens. CHANGE THIS to a long random string.
JWT_SECRET=change-this-to-a-long-random-secret-string

# The first admin account (created automatically on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Where the React site is served from (for CORS). Use * to allow all.
CORS_ORIGIN=*
